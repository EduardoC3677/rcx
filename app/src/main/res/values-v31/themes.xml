<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        On Android 12+ (API 31+), override colorPrimary and colorAccent with system dynamic
        colors from the Monet Engine (wallpaper-based color palette). DynamicColors from
        the Material library applies these automatically via RcxApplication.
        Text colors are intentionally omitted here so the MaterialComponents DayNight theme
        can supply appropriate light/dark defaults.
    -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@android:color/system_accent1_600</item>
        <item name="colorPrimaryDark">@android:color/system_accent1_700</item>
        <item name="colorAccent">@android:color/system_accent2_400</item>
        <item name="android:colorPrimary">@android:color/system_accent1_600</item>
        <item name="android:colorAccent">@android:color/system_accent2_400</item>
    </style>
</resources>
